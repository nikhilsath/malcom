{
  "name": "malcom-frontend-platform",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "malcom-frontend-platform",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "plugins/*"
      ]
    },
    "node_modules/@malcom/frontend-host": {
      "resolved": "packages/host",
      "link": true
    },
    "node_modules/@malcom/frontend-sdk": {
      "resolved": "packages/sdk",
      "link": true
    },
    "node_modules/@malcom/plugin-apis": {
      "resolved": "plugins/apis",
      "link": true
    },
    "node_modules/@malcom/plugin-automations": {
      "resolved": "plugins/automations",
      "link": true
    },
    "node_modules/@malcom/plugin-dashboard": {
      "resolved": "plugins/dashboard",
      "link": true
    },
    "node_modules/@malcom/plugin-docs": {
      "resolved": "plugins/docs",
      "link": true
    },
    "node_modules/@malcom/plugin-scripts": {
      "resolved": "plugins/scripts",
      "link": true
    },
    "node_modules/@malcom/plugin-settings": {
      "resolved": "plugins/settings",
      "link": true
    },
    "node_modules/@malcom/plugin-tools": {
      "resolved": "plugins/tools",
      "link": true
    },
    "packages/host": {
      "name": "@malcom/frontend-host",
      "version": "0.1.0"
    },
    "packages/sdk": {
      "name": "@malcom/frontend-sdk",
      "version": "0.1.0"
    },
    "plugins/apis": {
      "name": "@malcom/plugin-apis",
      "version": "0.1.0"
    },
    "plugins/automations": {
      "name": "@malcom/plugin-automations",
      "version": "0.1.0"
    },
    "plugins/dashboard": {
      "name": "@malcom/plugin-dashboard",
      "version": "0.1.0"
    },
    "plugins/docs": {
      "name": "@malcom/plugin-docs",
      "version": "0.1.0"
    },
    "plugins/scripts": {
      "name": "@malcom/plugin-scripts",
      "version": "0.1.0"
    },
    "plugins/settings": {
      "name": "@malcom/plugin-settings",
      "version": "0.1.0"
    },
    "plugins/tools": {
      "name": "@malcom/plugin-tools",
      "version": "0.1.0"
    }
  }
}
